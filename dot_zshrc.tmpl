# Aliases
function mkcommit () {
  claude -p 'check staged changes and create a conventional commit message. print only the message, no additional output, so it can be passed directly to git'
}

function cz () {
  code $(z -e $1)
}

function cfz () {
  code $(fzf)
}

function mkd () {
  mkdir -p $1 && cd $1
}

function telatun () {
  cloudflared tunnel run --url $1 roz-dev-tunnel
}

