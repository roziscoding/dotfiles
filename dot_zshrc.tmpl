function rd () {
    echo -n "Deleting $@. Continue? [y/n] "
    read REPLY
    case $REPLY in
      [Yy]) rm -rf $@ ;;
    esac
}

function yy () {
 local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" 
 yazi "$@" --cwd-file="$tmp"
 if cwd="$(cat -- "$tmp")"  && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]
 then
  cd -- "$cwd" || return
 fi
 rm -f -- "$tmp"
}

function ssh() {
  [ "$TERM" = "xterm-kitty" ] && command kitten ssh "$@" || command ssh "$@";
}

function cdtemp() {
  local tmp="$(mktemp -d $@)"
  cd $tmp
}

# Usage `aws-login <PROFILE>`
function aws-login() {
  local creds
  creds=$(aws configure export-credentials --profile $1 --format env 2>/dev/null)
  if [ $? -ne 0 ]; then
    aws sso login --profile $1
    creds=$(aws configure export-credentials --profile $1 --format env)
  fi
  eval "$creds"
}


