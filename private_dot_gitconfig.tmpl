# This is Git's per-user configuration file.
[user]
	name = Roz
{{- if stat (joinPath .chezmoi.homeDir ".ssh" "id_ed25519.pub") }}
	email = {{ output "cat" (joinPath .chezmoi.homeDir ".ssh" "id_ed25519.pub") | trim | splitList " " | last | quote }}
{{- else }}
	email = {{ .email | quote }}
{{- end }}
{{- $sshPubKey := joinPath .chezmoi.homeDir ".ssh" "id_ed25519.pub" }}
{{- if stat $sshPubKey }}
	signingkey = {{ output "cat" $sshPubKey | trim }}
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[commit]
	gpgsign = true
{{- end }}
[push]
  default = current
  followTags = true
[alias]
  prunef = "!git fetch --all --prune && git branch -vv | gawk '{print $1,$4}' | grep 'gone]' | gawk '{print $1}' | xargs git branch -D" 
  prune = "!git fetch --all --prune && git branch -vv | gawk '{print $1,$4}' | grep 'gone]' | gawk '{print $1}' | xargs git branch -d" 
  graph = log --all --graph --decorate --oneline --abbrev-commit
  gone = "!git branch -vv | gawk '{print $1,$4}' | grep 'gone]' | gawk '{print $1}'"
  amend = "commit --amend --no-edit"
  shove = "push --force-with-lease"
  co = "switch"
  cb = "checkout -B"
  c = "commit"
  cm = "commit -m"
  publish = "push -u origin HEAD"
  wipe = "!git checkout . && git clean -fd"
  nuke = "clean -fdx"
  prenuke = "clean -fdxn"
  uncommit = "!git reset --soft HEAD~1 && git reset"
  rh = reset --hard
  rs = reset --soft
	psf = push --force-with-lease
  apsf = !git amend && git psf
  ps = push -u
  pl = pull
	aa = add --all
  ai = add -i
  ap = add -p
	st = status
	l = log
  lo = log --oneline
  s = switch
[init]
  defaultBranch = main
[core]
  excludesFile = "~/.gitignore"
	whitespace = cr-at-eol
[url "git@github.com:"]
    insteadOf = https://github.com/
[url "git@gist.github.com:"]
    insteadOf = https://gist.github.com/
[merge]
  conflictStyle = diff3
[merge "identical"]
    name = Automatically resolve if files are textually identical (ignoring whitespace)
    driver = ~/.git-merge-drivers/identical.sh %A %B %A

