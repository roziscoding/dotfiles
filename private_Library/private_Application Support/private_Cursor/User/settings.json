{
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "always",
      "source.organizeImports": "never"
    }
  },
  "[vue]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.detectIndentation": false,
  "editor.fontFamily": "'JetBrainsMono Nerd Font Mono', Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.inlineSuggest.enabled": true,
  "editor.lineHeight": 1.8,
  "editor.minimap.enabled": false,
  "editor.renderLineHighlight": "gutter",
  "editor.rulers": [
    // {
    //   "color": "#f9e1af6f",
    //   "column": 80
    // },
    {
      "color": "#f38ba875",
      "column": 120
    }
  ],
  "editor.scrollbar.horizontal": "auto",
  "editor.scrollbar.vertical": "hidden",
  "editor.tabSize": 2,
  "editor.unicodeHighlight.nonBasicASCII": false,
  "eslint.format.enable": true,
  "explorer.compactFolders": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "Cargo.toml": "Cargo.lock"
  },
  "explorer.sortOrder": "foldersNestsFiles",
  "files.associations": {
    ".env*": "properties",
    "*.caddy": "caddyfile"
  },
  "files.autoSave": "onFocusChange",
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.views.contributors.files.layout": "tree",
  "http.proxySupport": "off",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.external.osxExec": "kitty",
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "JetbrainsMono Nerd Font Mono",
  "terminal.integrated.scrollback": 10000000000000,
  "terminal.integrated.showExitAlert": false,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "vim.cursorStylePerMode.replace": "underline",
  "window.commandCenter": false,
  "window.customTitleBarVisibility": "windowed",
  "window.dialogStyle": "custom",
  "window.nativeTabs": false,
  "window.titleBarStyle": "custom",
  "workbench.editor.labelFormat": "short",
  "workbench.iconTheme": "bearded-icons",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "workbench.sideBar.location": "right",
  "workbench.tree.indent": 20,
  "eslint.useESLintClass": true,
  "editor.semanticHighlighting.enabled": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "[json]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "never",
      "source.fixAll.ts": "never",
      "source.addMissingImports.ts": "never",
      "source.organizeImports": "never",
      "source.removeUnused.ts": "never",
      "source.removeUnusedImports": "never",
      "source.sortImports": "never"
    }
  },
  "editor.inlayHints.enabled": "offUnlessPressed",
  "vim.smartRelativeLine": true,
  "vue.server.hybridMode": true,
  "editor.accessibilitySupport": "off",
  "editor.formatOnSave": true,
  "window.autoDetectHighContrast": false,
  "git.autofetch": true,
  "security.promptForLocalFileProtocolHandling": false,
  "editor.stickyScroll.enabled": false,
  "breadcrumbs.enabled": false,
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "One Dark Pro",
  "workbench.preferredHighContrastLightColorTheme": "Catppuccin Latte",
  "workbench.preferredHighContrastColorTheme": "Cursor Dark High Contrast",
  "vim.easymotion": true,
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.chat.terminalShowHoverHint": false,
}