#!/bin/bash
set -euo pipefail

KEY_PATH="$HOME/.ssh/id_ed25519"

if [ -f "$KEY_PATH" ]; then
  echo "SSH key already exists at $KEY_PATH, skipping generation."
  exit 0
fi

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

echo "Generating new SSH key..."
ssh-keygen -t ed25519 -C {{ .email | quote }} -f "$KEY_PATH" -N ""

echo "SSH key generated at $KEY_PATH"
echo "Public key:"
cat "${KEY_PATH}.pub"
